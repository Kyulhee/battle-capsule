# Godot 4 임시/캐시 파일
.godot/

# 내보낸 빌드 (배포는 GitHub Releases 등 별도 사용)
*.exe
*.pck
*.console.exe

# 에셋 임포트 메타데이터 (자동 생성)
*.import

# 내보내기 자격증명 (민감 정보)
export_credentials.cfg

# 디버그 스크린샷 (자동 생성)
debug_screenshot*.png

# 시뮬레이션 결과 (tools/simulate_matches.py 실행 결과물)
tools/simulation_results.json

# Python 캐시
__pycache__/
*.pyc
