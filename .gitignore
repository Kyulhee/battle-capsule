# Godot 4 임시/캐시 파일
.godot/

# 빌드 아티팩트 (배포는 GitHub Releases 사용)
builds/
*.exe
*.pck
*.console.exe
*.zip

# 에셋 임포트 메타데이터 (자동 생성)
*.import

# 내보내기 자격증명 (민감 정보)
export_credentials.cfg

# 디버그 스크린샷 (자동 생성)
debug_screenshot*.png

# Python 캐시
__pycache__/
*.pyc

# 시뮬레이션 결과 데이터
tools/*.json

# Claude Code 프로젝트 설정 (API 키 포함 — 절대 커밋 금지)
.claude/
